{
  "info": {
    "name": "Food Delivery Platform",
    "description": "Complete API collection for the Food Delivery Platform microservices system. All requests go through the API Gateway at http://localhost:8080.\n\nSetup:\n1. Start all services (locally or via Docker)\n2. Run 'Register Customer' then 'Login' — the token is saved automatically\n3. Follow the Full Order Flow folder for end-to-end testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "customerId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "restaurantId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "menuItemId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "deliveryId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "ownerUsername",
      "value": "divine",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Customer",
      "description": "Customer registration, login, and profile endpoints.",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"divine\",\n    \"password\": \"password123\",\n    \"email\": \"divine@example.com\",\n    \"phone\": \"0241234567\",\n    \"address\": \"123 Main Street\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "register"]
            },
            "description": "Register a new customer. No JWT required. Returns a token on success."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.token) {",
                  "        pm.collectionVariables.set('token', json.token);",
                  "        console.log('Token saved:', json.token);",
                  "    }",
                  "}",
                  "pm.test('Registration successful', function() {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"divine\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "login"]
            },
            "description": "Login and get a JWT token. Token is automatically saved to the collection variable and used in all subsequent requests."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.token) {",
                  "        pm.collectionVariables.set('token', json.token);",
                  "        console.log('Token saved automatically:', json.token);",
                  "    }",
                  "}",
                  "pm.test('Login successful', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Token returned', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.token).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
