    {
      "name": "Full Order Flow",
      "description": "Run these requests in order to verify the complete end-to-end flow:\n\n1. Register Customer\n2. Login (saves token automatically)\n3. Create Restaurant (saves restaurantId automatically)\n4. Add Menu Item (saves menuItemId automatically)\n5. Place Order (saves orderId automatically)\n6. Get All Deliveries (verify auto-assignment, saves deliveryId)\n7. Update Status to PICKED_UP\n8. Update Status to DELIVERED\n9. Verify Order Status\n\nAll variables are saved automatically between steps.",
      "item": [
        {
          "name": "1. Register Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"testuser\",\n    \"password\": \"password123\",\n    \"email\": \"testuser@example.com\",\n    \"phone\": \"0241234567\",\n    \"address\": \"123 Main Street\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.token) pm.collectionVariables.set('token', json.token);",
                  "}",
                  "pm.test('Step 1 - Registration successful', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2. Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"testuser\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Step 2 - Login successful', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);",
                  "console.log('Token saved:', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3. Create Restaurant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Flow Test Restaurant\",\n    \"address\": \"456 Food Street\",\n    \"city\": \"Accra\",\n    \"cuisineType\": \"Italian\",\n    \"description\": \"Test restaurant for order flow\",\n    \"phone\": \"0209876543\",\n    \"estimatedDeliveryMinutes\": 23\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/restaurants?ownerId={{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "restaurants"],
              "query": [
                {
                  "key": "ownerId",
                  "value": "{{customerId}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Step 3 - Restaurant created', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('restaurantId', json.id.toString());",
                  "console.log('Restaurant ID saved:', json.id);"
                ],
