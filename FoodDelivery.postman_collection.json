{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-1234-56789abcdef0",
    "name": "Food Delivery Platform (Fixed)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "customerId", "value": "" },
    { "key": "restaurantId", "value": "" },
    { "key": "menuItemId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Register Customer",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"divine\",\n  \"password\": \"password123\",\n  \"email\": \"divine@example.com\",\n  \"phone\": \"0241234567\",\n  \"firstName\": \"Divine\",\n  \"lastName\": \"Tester\",\n  \"address\": \"123 Main Street\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/customers/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('token', json.token);",
              "if (json.id) pm.collectionVariables.set('customerId', json.id.toString());",
              "pm.test('Registration OK', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"divine\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/customers/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('token', json.token);",
              "if (json.id) pm.collectionVariables.set('customerId', json.id.toString());",
              "pm.test('Login OK', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Restaurant",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Restaurant\",\n  \"address\": \"456 Food Street\",\n  \"city\": \"Accra\",\n  \"cuisineType\": \"Italian\",\n  \"description\": \"Test restaurant\",\n  \"phone\": \"0209876543\",\n  \"estimatedDeliveryMinutes\": 30\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/restaurants?ownerId={{customerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "restaurants"],
          "query": [
            { "key": "ownerId", "value": "{{customerId}}" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.id) pm.collectionVariables.set('restaurantId', json.id.toString());",
              "pm.test('Restaurant created', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "Add Menu Item",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Margherita Pizza\",\n  \"description\": \"Classic pizza\",\n  \"price\": 15.99,\n  \"available\": true,\n  \"category\": \"Main\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/restaurants/{{restaurantId}}/menu?OwnerUsername=divine",
          "host": ["{{baseUrl}}"],
          "path": ["api", "restaurants", "{{restaurantId}}", "menu"],
          "query": [
            { "key": "OwnerUsername", "value": "divine" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.id) pm.collectionVariables.set('menuItemId', json.id.toString());",
              "pm.test('Menu item added', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "Place Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": {{customerId}},\n  \"restaurantId\": {{restaurantId}},\n  \"deliveryAddress\": \"123 Test Street\",\n  \"specialInstructions\": \"No onions\",\n  \"items\": [\n    {\n      \"menuItemId\": {{menuItemId}},\n      \"quantity\": 2,\n      \"unitPrice\": 15.99\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders"]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.request.body.raw = JSON.stringify({",
              "  customerId: pm.collectionVariables.get('customerId') || 1,",
              "  restaurantId: pm.collectionVariables.get('restaurantId') || 1,",
              "  deliveryAddress: '123 Test Street',",
              "  specialInstructions: 'No onions',",
              "  items: [",
              "    {",
              "      menuItemId: pm.collectionVariables.get('menuItemId') || 1,",
              "      quantity: 2,",
              "      unitPrice: 15.99",
              "    }",
              "  ]",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.id) pm.collectionVariables.set('orderId', json.id.toString());",
              "pm.test('Order placed', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "Rate Limit Test",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": {{customerId}},\n  \"restaurantId\": {{restaurantId}},\n  \"deliveryAddress\": \"123 Test Street\",\n  \"items\": [\n    {\n      \"menuItemId\": {{menuItemId}},\n      \"quantity\": 1,\n      \"unitPrice\": 15.99\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.collectionVariables.get('count')) {",
              "  pm.collectionVariables.set('count', 1);",
              "} else {",
              "  let c = parseInt(pm.collectionVariables.get('count'));",
              "  pm.collectionVariables.set('count', c + 1);",
              "}",
              "let count = pm.collectionVariables.get('count');",
              "if (count <= 5) {",
              "  pm.test('Within limit', () => pm.response.to.have.status(200));",
              "} else {",
              "  pm.test('Rate limited', () => pm.response.to.have.status(429));",
              "}"
            ]
          }
        }
      ]
    }
  ]
}